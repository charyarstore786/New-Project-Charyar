// Data model for the direct-booking engine (see PLAN.md).
// Postgres (Neon) in production and local dev alike, via DATABASE_URL.
// Status fields are kept as plain strings (not native enums) since this
// schema started on SQLite, which has no enum support — allowed values are
// documented next to each field and enforced in lib/booking.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Guest {
  id                 String    @id @default(cuid())
  name               String
  email              String
  phone              String
  country            String?
  // UNVERIFIED | PENDING | VERIFIED | FAILED
  verificationStatus String    @default("UNVERIFIED")
  // Minimal summary extracted from the ID check (JSON: docType, docNumber
  // masked, dob, expiry). Document images stay in Stripe Identity, never here.
  idSummary          String?
  createdAt          DateTime  @default(now())
  bookings           Booking[]
}

model Booking {
  id                    String        @id @default(cuid())
  // Human-friendly reference shown to the guest, e.g. NS-4F7K2M
  reference             String        @unique
  // Date-only values stored at midnight UTC; checkOut is exclusive
  checkIn               DateTime
  checkOut              DateTime
  guests                Int
  // Money in pence
  nightlyRate           Int
  nights                Int
  cleaningFee           Int
  total                 Int
  // PENDING_VERIFICATION | PENDING_APPROVAL | APPROVED | CHECKED_IN |
  // CHECKED_OUT | CLOSED | REJECTED | CANCELLED
  status                String        @default("PENDING_VERIFICATION")
  guestId               String
  guest                 Guest         @relation(fields: [guestId], references: [id])
  stripeCustomerId      String?
  stripePaymentIntentId String?
  stripeSetupIntentId   String?
  stripeDepositIntentId String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  damageClaims          DamageClaim[]
  emails                EmailLog[]

  @@index([checkIn, checkOut])
  @@index([status])
}

// External bookings/blocks imported from the Sympl iCal feed
model CalendarBlock {
  id       String   @id @default(cuid())
  // iCal UID — upsert key so re-imports stay idempotent
  uid      String   @unique
  start    DateTime
  end      DateTime
  summary  String?
  source   String   @default("sympl")
  syncedAt DateTime @default(now())

  @@index([start, end])
}

model EmailLog {
  id        String   @id @default(cuid())
  bookingId String?
  booking   Booking? @relation(fields: [bookingId], references: [id])
  // CONFIRMATION | CHECK_IN_INSTRUCTIONS | CHECK_OUT_INSTRUCTIONS |
  // REJECTED | DEPOSIT_FAILED | ...
  type      String
  to        String
  subject   String
  body      String
  sentAt    DateTime @default(now())

  // Idempotency guard for cron-triggered emails
  @@unique([bookingId, type])
}

model EventLog {
  id        String   @id @default(cuid())
  bookingId String?
  type      String
  detail    String?
  createdAt DateTime @default(now())

  @@index([bookingId])
}

model DamageClaim {
  id             String   @id @default(cuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id])
  amount         Int
  note           String
  stripeChargeId String?
  createdAt      DateTime @default(now())
}

// Single-row table (id is always "singleton") holding the admin-editable
// pricing/policy that used to be hardcoded in lib/site.ts. Falls back to
// those hardcoded values (see lib/pricing.ts) until a row is saved.
model Setting {
  id          String   @id @default("singleton")
  nightlyRate Int // pence
  cleaningFee Int // pence
  deposit     Int // pence
  minNights   Int
  maxNights   Int
  maxGuests   Int
  // Sympl (or other) iCal feed URL to import external blocks from. Admin-editable
  // (see /admin/sync) so it doesn't need a Vercel env var — falls back to
  // SYMPL_ICAL_URL if this is unset (see lib/channel-manager).
  symplIcalUrl String?
  updatedAt   DateTime @updatedAt
}

// Date-range promotional pricing. endDate is exclusive (same convention as
// Booking.checkOut). When multiple active deals overlap the same night, the
// earliest-created one wins (see lib/pricing.ts).
model Deal {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  // PERCENTAGE_OFF | FIXED_RATE
  type      String
  // percentage 1-100 for PERCENTAGE_OFF, pence for FIXED_RATE
  value     Int
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate, endDate])
}

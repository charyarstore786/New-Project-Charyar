# --- Database ---------------------------------------------------------------
# Postgres connection string (Neon in production and local dev alike).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://shortstaynewport.co.uk"

# --- External services ------------------------------------------------------
# Every service runs in MOCK mode when its key/URL below is left empty.
# Fill a value in and the real integration switches on (see PLAN.md).

# Stripe (payments + Identity)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Sympl channel sync — the iCal export URL from your Sympl dashboard
SYMPL_ICAL_URL=""

# Resend (transactional email)
RESEND_API_KEY=""
EMAIL_FROM="Short Stay Newport <bookings@shortstaynewport.co.uk>"

# Anthropic (AI guest assistant)
ANTHROPIC_API_KEY=""

# Admin dashboard password
ADMIN_PASSWORD="change-me"


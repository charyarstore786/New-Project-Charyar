# --- Database ---------------------------------------------------------------
# Postgres connection string (Neon in production and local dev alike).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Site -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://shortstaynewport.co.uk"

# --- External services ------------------------------------------------------
# Every service runs in MOCK mode when its key/URL below is left empty.
# Fill a value in and the real integration switches on (see PLAN.md).

# Stripe (payments + Identity)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Sympl channel sync — the iCal export URL from your Sympl dashboard.
# Optional: can also be set from /admin/sync instead, which takes priority.
SYMPL_ICAL_URL=""

# Resend (transactional email)
RESEND_API_KEY=""
EMAIL_FROM="Short Stay Newport <bookings@shortstaynewport.co.uk>"

# Resend inbound (two-way guest messaging — see app/api/webhooks/resend-inbound
# and the "Messages" card on an admin booking page). Both empty = guest
# replies just go nowhere special, same as before this feature existed.
# INBOUND_EMAIL_DOMAIN: a subdomain added as a Receiving domain in the Resend
# dashboard (e.g. "inbound.shortstaynewport.co.uk") — needs its own MX record,
# kept separate from the main domain so it can't collide with any existing
# mail routing on shortstaynewport.co.uk.
# RESEND_WEBHOOK_SECRET: the signing secret from the Resend webhook you point
# at /api/webhooks/resend-inbound, subscribed to the "email.received" event.
INBOUND_EMAIL_DOMAIN=""
RESEND_WEBHOOK_SECRET=""

# Mapbox (geocodes a guest's address to decide auto- vs manual-approval —
# see lib/geo.ts). Any address is treated as unresolved (defaults to
# auto-approve) when this is empty.
MAPBOX_ACCESS_TOKEN=""

# Anthropic (AI guest assistant)
ANTHROPIC_API_KEY=""

# Admin dashboard password
ADMIN_PASSWORD="change-me"

# Cron authorization — set this in Vercel's project env vars and Vercel will
# automatically send it as "Authorization: Bearer $CRON_SECRET" when it
# triggers /api/cron/daily (see vercel.json). Generate any random string.
CRON_SECRET=""

# --- Private guest-instructions (server-only — NEVER exposed to the public
# site, only used server-side for the post-approval confirmation email) ----
PROPERTY_UNIT_ADDRESS="2A Kingston Road, Newport, NP19 0BP"
PROPERTY_ENTRY_INSTRUCTIONS="Your private studio apartment is located at the rear of the garden, accessible via the black door marked 2A."
PROPERTY_KEY_BOX_CODE="4268"
